<section class="py-16">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="text-3xl font-bold text-gray-900 text-center mb-12">Get In Touch</h1>

    <!-- Success banner -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div role="alert" class="mb-8 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md">
        <svg class="h-5 w-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>Your message was sent successfully. I'll be in touch soon!</span>
      </div>
    <% } %>

    <!-- Error banner -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div role="alert" class="mb-8 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md">
        <svg class="h-5 w-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <span><%= error %></span>
      </div>
    <% } %>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-semibold text-gray-800 mb-6">Contact Information</h2>
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Email</h3>
              <a href="mailto:<%= contactInfo.email %>" class="text-blue-600 hover:underline"><%= contactInfo.email %></a>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Phone</h3>
              <a href="tel:<%= contactInfo.phone %>" class="text-gray-600 hover:text-blue-600"><%= contactInfo.phone %></a>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Location</h3>
              <p class="text-gray-600"><%= contactInfo.address %></p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Social</h3>
              <div class="flex space-x-4 mt-2">
                <a href="<%= contactInfo.social.github %>"   class="text-gray-600 hover:text-blue-600 font-medium" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="<%= contactInfo.social.linkedin %>" class="text-gray-600 hover:text-blue-600 font-medium" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                <a href="<%= contactInfo.social.twitter %>"  class="text-gray-600 hover:text-blue-600 font-medium" target="_blank" rel="noopener noreferrer">Twitter</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-semibold text-gray-800 mb-6">Send Me a Message</h2>
        <form action="/contact" method="POST" class="space-y-6" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
              Full Name <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              maxlength="100"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="Jane Doe"
            >
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              Email Address <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              maxlength="254"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="jane@example.com"
            >
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
              Message <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              maxlength="2000"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-y"
              placeholder="Tell me about your project or opportunity…"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 active:bg-blue-800 transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
