<section class="py-16">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="text-3xl font-bold text-gray-900 text-center mb-12">Get In Touch</h1>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl font-semibold text-gray-800 mb-6">Contact Information</h2>
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 text-blue-600">??</div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Email</h3>
              <p class="text-gray-600"><%= contactInfo.email %></p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 text-blue-600">??</div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Phone</h3>
              <p class="text-gray-600"><%= contactInfo.phone %></p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 text-blue-600">??</div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Location</h3>
              <p class="text-gray-600"><%= contactInfo.address %></p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 text-blue-600">??</div>
            <div class="ml-3">
              <h3 class="font-medium text-gray-900">Social</h3>
              <div class="flex space-x-4 mt-2">
                <a href="<%= contactInfo.social.github %>" class="text-gray-600 hover:text-blue-600" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="<%= contactInfo.social.linkedin %>" class="text-gray-600 hover:text-blue-600" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                <a href="<%= contactInfo.social.twitter %>" class="text-gray-600 hover:text-blue-600" target="_blank" rel="noopener noreferrer">Twitter</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <h2 class="text-2xl font-semibold text-gray-800 mb-6">Send Me a Message</h2>
        <form action="/contact" method="POST" class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
          </div>
          <button type="submit" class="w-full bg-blue-600 text-white px-6 py-3 rounded-md hover:bg-blue-700 transition">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>
