<section class="py-16">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="text-3xl font-bold text-gray-900 text-center mb-12">My Projects</h1>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% projects.forEach(function(project) { %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
          <img src="<%= project.image || '/images/placeholder.jpg' %>" alt="<%= project.title %>" class="w-full h-48 object-cover">
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= project.title %></h3>
            <p class="text-gray-600 mb-4"><%= project.description %></p>
            <div class="mb-4">
              <% project.technologies.forEach(function(tech) { %>
                <span class="inline-block bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded mr-2 mb-2"><%= tech %></span>
              <% }) %>
            </div>
            <a href="<%= project.url %>" class="inline-block bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition">View Project</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-gray-50 py-12">
  <div class="max-w-4xl mx-auto px-4 ft">
    <h2 class="text-2xl font-semibold text-gray-800 text-center mb-10">Technologies I Work With</h2>
    <div class="flex flex-wrap justify-center gap-4">
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">JavaScript</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">Node.js</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">React</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">Vue.js</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">Tailwind CSS</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">MongoDB</span>
      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-3 py-1 rounded">MySQL</span>
    </div>
  </div>
</section>
