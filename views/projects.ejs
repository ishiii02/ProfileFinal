<section class="py-16">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="text-3xl font-bold text-gray-900 text-center mb-12">My Projects</h1>

    <% if (!projects || projects.length === 0) { %>
      <p class="text-center text-gray-500">No projects to display yet. Check back soon!</p>
    <% } else { %>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% projects.forEach(function(project) { %>
          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow flex flex-col">
            <img
              src="<%= project.image || '/images/placeholder.jpg' %>"
              alt="Screenshot of <%= project.title %>"
              class="w-full h-48 object-cover"
              loading="lazy"
              onerror="this.src='/images/placeholder.jpg'; this.onerror=null;"
            >
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= project.title %></h3>
              <p class="text-gray-600 mb-4 flex-grow"><%= project.description %></p>
              <div class="mb-4">
                <% project.technologies.forEach(function(tech) { %>
                  <span class="inline-block bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded mr-2 mb-2"><%= tech %></span>
                <% }) %>
              </div>
              <a
                href="<%= project.url %>"
                class="inline-block bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition text-center focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                <% if (project.url && project.url !== '#') { %>target="_blank" rel="noopener noreferrer"<% } %>
              >
                View Project
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="bg-gray-50 py-12">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-2xl font-semibold text-gray-800 text-center mb-8">Technologies I Work With</h2>
    <div class="flex flex-wrap justify-center gap-3">
      <% ['JavaScript','Node.js','React','Vue.js','Tailwind CSS','MongoDB','MySQL','Express.js','EJS','Git'].forEach(function(t) { %>
        <span class="bg-blue-100 text-blue-800 text-sm font-medium px-3 py-1 rounded-full"><%= t %></span>
      <% }) %>
    </div>
  </div>
</section>
